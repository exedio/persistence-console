package com.exedio.cope.console;

final class Inspections_Jspm
{
	static void writeBody(
			final Out out,
			final ConsoleCop<?>[] targets)
	{
		%>
		<div>Finds possible issues in the model.</div><%
		%>
		<ul><%

		for(final ConsoleCop<?> target : targets)
		{
			final String[] help = target.getHeadingHelp();
			%>
			<li><a href="<%=target%>"><%=target.name%></a><%
				if(help.length>=1) { %> - <%=help[0]%><% }
				%></li><%
		}
		%>
			<li>Number Is Not Zero - Value zero is allowed, but does not appear in database (not yet implemented).</li>
			<li>Number Is Not Negative - Negative values are allowed, but do not appear in database (not yet implemented).</li>
			<li>Type Is Empty - There are no items of a type in database at all. (not yet implemented).</li>
		</ul><%
	}

	private Inspections_Jspm()
	{
		// prevent instantiation
	}
}%>
